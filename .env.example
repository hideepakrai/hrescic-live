# Core database configuration
MONGODB_URI="mongodb+srv://<user>:<password>@cluster.example.mongodb.net/?retryWrites=true&w=majority"
TENANT_DB_NAME="hrescic_tenant"

# Required for admin authentication
JWT_SECRET="replace-with-a-strong-random-secret"

# Public canonical base URL used for metadata/canonical tags
APP_URL="https://www.hrescic.com"

# Optional: reCAPTCHA secret for public lead form verification
# If omitted, API accepts the local placeholder token `local-pass` only.
RECAPTCHA_SECRET_KEY=""

# Optional: keep legacy `/api/pages` and `/api/comments` public
# Recommended to keep this disabled in production.
ENABLE_LEGACY_PUBLIC_APIS="false"

# Optional: SMTP notifications for newly submitted leads
# Enable with "true" only after all SMTP values are configured.
LEAD_EMAIL_NOTIFICATIONS_ENABLED="false"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL=""
SMTP_FROM_NAME="Hrescic"
LEAD_NOTIFY_TO=""
